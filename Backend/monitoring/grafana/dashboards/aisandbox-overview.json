{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Request rate (req/s) by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "title": "Error rate (5xx) by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "title": "JVM heap used by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (application) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "title": "Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "{app=~\".+-service\"}" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["aisandbox"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "AI-Sandbox Overview",
  "uid": "aisandbox-overview",
  "version": 1
}
