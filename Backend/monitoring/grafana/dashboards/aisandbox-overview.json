{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Request rate (req/s) by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "title": "Error rate (5xx) by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "title": "JVM heap used by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (application) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "title": "Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "{app=~\".+-service\"}" }
      ]
    },
    {
      "title": "Latency p95 / p99 by endpoint",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Per-endpoint request latency from http_server_requests histogram buckets (requires management.metrics.distribution.percentiles-histogram.http.server.requests=true).",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, application, uri) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p95 {{application}} {{uri}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, application, uri) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p99 {{application}} {{uri}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["aisandbox"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "AI-Sandbox Overview",
  "uid": "aisandbox-overview",
  "version": 1
}
