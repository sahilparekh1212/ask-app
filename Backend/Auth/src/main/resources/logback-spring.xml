<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="auth-service"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>[${appName}] %d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} pod=${HOSTNAME:-local} traceId=%X{traceId:-} spanId=%X{spanId:-} requestId=%X{requestId:-} userId=%X{userId:-anonymous} threadId=%thread url=%X{urlParts:-/} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Ship logs to Grafana Loki in deployed environments. LOKI_URL overrides the target. -->
    <springProfile name="DEV,SIT,UAT,PROD">
        <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
            <http>
                <url>${LOKI_URL:-http://loki:3100/loki/api/v1/push}</url>
            </http>
            <!-- loki4j 2.x syntax: labels are a top-level newline-separated block. The 1.x
                 <format><label><pattern> form is silently ignored by 2.x, which shipped every
                 line under app=default and blanked the dashboard's {app=~".+-service"} panel. -->
            <labels>
                app=${appName}
                host=${HOSTNAME:-local}
                level=%level
            </labels>
            <message>
                <pattern>[${appName}] %d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} pod=${HOSTNAME:-local} traceId=%X{traceId:-} spanId=%X{spanId:-} requestId=%X{requestId:-} userId=%X{userId:-anonymous} threadId=%thread url=%X{urlParts:-/} - %msg</pattern>
            </message>
        </appender>
    </springProfile>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <springProfile name="DEV,SIT,UAT,PROD">
            <appender-ref ref="LOKI"/>
        </springProfile>
    </root>
</configuration>
